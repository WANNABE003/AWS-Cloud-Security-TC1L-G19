aws_region        = "ap-southeast-1"
repository_url    = "https://github.com/YOUR-GITHUB-USER/YOUR-REPOSITORY.git"
repository_branch = "main"
alert_email       = "you@example.com"

# Keep these false for the lowest-cost deployment.
enable_alb = false
enable_waf = false

# Rubric demo mode (billable) requires all three values below instead:
# enable_alb      = true
# enable_waf      = true
# certificate_arn = "arn:aws:acm:ap-southeast-1:123456789012:certificate/uuid"
# application_domain = "shop.example.com"
